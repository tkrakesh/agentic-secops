# Project Sentinel — Environment Configuration
# Copy to .env and fill in the values below

# ── Google Cloud / Vertex AI ────────────────────────────────────────────────────
# Force ADK to route model calls through Vertex AI instead of AI Studio APIs
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Default model used by orchestrator and sub-agents
# Note: google/ prefix is required for Vertex AI routing in ADK
SECOPS_MODEL_FLASH=gemini-2.5-flash
SECOPS_MODEL_PRO=gemini-2.5-pro

# ── Agentspace Playbooks (RAG) ──────────────────────────────────────────────────
# The Vertex AI Search datastore ID containing the playbook corpus.
# Format: projects/.../dataStores/YOUR_ID
# If left empty, Sentinel falls back to local TF-IDF POC search over data/playbooks/
AGENTSPACE_DATASTORE_ID=

# ── SecOps MCP Server ───────────────────────────────────────────────────────────
# The Cloud Run HTTPS endpoint for the standalone SecOps MCP server.
# If left empty, Sentinel falls back to local FunctionTools wrapping fixture data.
SECOPS_MCP_URL=https://sentinel-secops-mcp-HASH-uc.a.run.app

# ── Agent Engine ────────────────────────────────────────────────────────────────
# Resource ID for the deployed Agent Engine backend (used by Streamlit UI)
AGENT_ENGINE_RESOURCE_ID=
